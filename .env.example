# ─────────────────────────────────────────────────────────────────────────────
#  Alfa Invest — Environment Variables
#  Copy this file to .env and fill in all values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL (CMS database) ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=alfainvest_cms
MYSQL_USER=alfainvest
MYSQL_PASSWORD=change_me_mysql_password

# ── PostgreSQL (Umami database) ───────────────────────────────────────────────
POSTGRES_DB=umami
POSTGRES_USER=umami
POSTGRES_PASSWORD=change_me_postgres_password

# ── CMS Admin — Session / Auth ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_at_least_64_chars_long

# ── Manus OAuth (required for admin login) ────────────────────────────────────
# These values come from your Manus project settings.
# If you are self-hosting without Manus OAuth, you need to replace the auth
# mechanism in server/_core/oauth.ts with your own provider.
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im
OWNER_OPEN_ID=your_manus_open_id
OWNER_NAME=Your Name

# ── Manus Forge APIs (optional — LLM, storage, etc.) ─────────────────────────
# Leave empty if not using Manus platform features.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Umami Analytics ───────────────────────────────────────────────────────────
# Secret used by Umami to sign tokens. Generate with: openssl rand -hex 32
UMAMI_APP_SECRET=change_me_umami_app_secret

# Optional: pre-configure Umami credentials in the CMS admin.
# You can also set these later from the Settings page in the admin UI.
UMAMI_URL=http://umami:3000
UMAMI_USERNAME=admin
UMAMI_PASSWORD=umami_admin_password
UMAMI_WEBSITE_ID=

# ── Public Site ───────────────────────────────────────────────────────────────
# The URL of the CMS admin API as seen FROM THE BROWSER (not Docker internal).
# In production use your actual domain: https://cms.yourdomain.com
# In local development: http://localhost:3000
PUBLIC_SITE_CMS_URL=http://localhost:3000
